---
import type { ProjectEntry } from '../../utils/projects'
import {
  formatProjectMonth,
  getProjectPath,
  getProjectStatusLabel,
} from '../../utils/projects'
import ProjectMedia from '../projects/ProjectMedia.astro'

interface Props {
  entry: ProjectEntry
  headingLevel?: 'h2' | 'h3'
  preview?: boolean
}

const { entry, headingLevel = 'h3', preview = false } = Astro.props
const Heading = headingLevel
const { description, repositoryUrl, stack, startedAt, status, title } =
  entry.data
const detailHref = getProjectPath(entry.id)
const statusLabel = getProjectStatusLabel(status)
---

<article class:list={['project-card', { 'project-card--preview': preview }]}>
  <a
    class="project-card__media-link"
    href={detailHref}
    aria-label={`${title} 프로젝트 상세 보기`}
  >
    <ProjectMedia entry={entry} />
  </a>

  <div class="project-card__body">
    <div class="project-card__eyebrows">
      <span>{statusLabel}</span>
      {preview && <span class="project-card__preview">Draft Preview</span>}
    </div>

    <Heading class="project-card__title">
      <a href={detailHref}>{title}</a>
    </Heading>

    <p class="project-card__description">{description}</p>

    {
      startedAt && (
        <p class="project-card__date">
          <span class="sr-only">시작일: </span>
          {formatProjectMonth(startedAt)}
        </p>
      )
    }

    <ul class="project-card__stack" aria-label={`${title} 사용 기술`}>
      {stack.map((item) => <li>{item}</li>)}
    </ul>

    <div class="project-card__links">
      <a class="project-card__detail-link" href={detailHref}>
        프로젝트 보기 <span aria-hidden="true">→</span>
      </a>
      {
        repositoryUrl && (
          <a
            class="project-card__external-link"
            href={repositoryUrl}
            target="_blank"
            rel="noreferrer"
          >
            GitHub 저장소 <span aria-hidden="true">↗</span>
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    height: 100%;
    min-width: 0;
    flex-direction: column;
    overflow: hidden;
    border: var(--site-border-thin) solid var(--site-color-border);
    border-radius: var(--site-radius-xl);
    background: var(--site-color-surface);
    transition: border-color var(--site-duration-base) var(--site-ease-out);
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: color-mix(in srgb, var(--site-color-accent) 60%, transparent);
  }

  .project-card--preview {
    border-style: dashed;
  }

  .project-card--preview:hover,
  .project-card--preview:focus-within {
    border-style: solid;
  }

  .project-card__media-link {
    display: block;
    overflow: hidden;
    border-radius: calc(var(--site-radius-xl) - 1px)
      calc(var(--site-radius-xl) - 1px) 0 0;
  }

  .project-card:hover :global([data-project-cover]),
  .project-card:focus-within :global([data-project-cover]) {
    transform: scale(1.05);
  }

  .project-card__body {
    display: flex;
    min-height: 0;
    flex: 1;
    flex-direction: column;
    padding: clamp(1.25rem, 4vw, 1.5rem);
  }

  .project-card__eyebrows {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--site-color-accent);
    font-size: var(--site-text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-card__preview {
    border: var(--site-border-thin) solid
      color-mix(in srgb, var(--site-color-accent) 45%, transparent);
    border-radius: var(--site-radius-pill);
    padding: 0.18rem 0.5rem;
    background: color-mix(in srgb, var(--site-color-accent) 10%, transparent);
  }

  .project-card__title {
    margin: 0.75rem 0 0;
    color: var(--site-color-text);
    font-size: var(--site-text-xl);
    line-height: 1.3;
    overflow-wrap: break-word;
    text-wrap: balance;
    word-break: keep-all;
  }

  .project-card__title a {
    transition: color var(--site-duration-base) var(--site-ease-out);
  }

  .project-card__title a:hover,
  .project-card__title a:focus-visible {
    color: var(--site-color-accent);
  }

  .project-card__description {
    display: -webkit-box;
    margin: 0.65rem 0 0;
    overflow: hidden;
    color: var(--site-color-text-muted);
    font-size: var(--site-text-sm);
    line-height: 1.65;
    overflow-wrap: break-word;
    text-wrap: pretty;
    word-break: keep-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .project-card__date {
    margin: 0.9rem 0 0;
    color: var(--site-color-text-muted);
    font-size: var(--site-text-xs);
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-card__stack li {
    border: var(--site-border-thin) solid var(--site-color-border);
    border-radius: var(--site-radius-pill);
    background: var(--site-color-surface-muted);
    padding: 0.25rem 0.65rem;
    color: var(--site-color-text-muted);
    font-size: var(--site-text-xs);
    font-weight: 600;
    overflow-wrap: break-word;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-top: auto;
    border-top: var(--site-border-thin) solid var(--site-color-border);
    padding-top: 1.1rem;
    transform: translateY(1.1rem);
  }

  .project-card__links a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.3rem;
    border-radius: var(--site-radius-sm);
    color: var(--site-color-text-muted);
    font-size: var(--site-text-sm);
    font-weight: 650;
    transition: color var(--site-duration-fast) var(--site-ease-out);
  }

  .project-card__links a:hover,
  .project-card__links a:focus-visible {
    color: var(--site-color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__title a,
    .project-card__links a,
    .project-card :global([data-project-cover]) {
      transition: none;
    }
  }
</style>
