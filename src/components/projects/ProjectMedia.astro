---
import type { ProjectEntry } from '../../utils/projects'
import { getProjectStatusLabel } from '../../utils/projects'

interface Props {
  entry: ProjectEntry
  eager?: boolean
  sizes?: string
}

const {
  entry,
  eager = false,
  sizes = '(min-width: 1024px) 50vw, 100vw',
} = Astro.props
const { cover, status, title } = entry.data
const statusLabel = getProjectStatusLabel(status)
---

<div class="project-media" data-project-media>
  {
    cover ? (
      <img
        data-project-cover
        src={cover.src}
        alt={cover.alt}
        width={cover.width}
        height={cover.height}
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding="async"
        sizes={sizes}
      />
    ) : (
      <div
        class="project-media__fallback"
        role="img"
        aria-label={`${title} 프로젝트를 위한 추상적인 브랜드 그래픽`}
      >
        <div class="project-media__grid" aria-hidden="true" />
        <div class="project-media__fallback-content" aria-hidden="true">
          <span class="project-media__wordmark">CHEEZCYJ</span>
          <strong>Astro / Portfolio Redesign</strong>
          <span>{statusLabel}</span>
        </div>
      </div>
    )
  }
</div>

<style>
  .project-media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--site-color-surface-muted);
  }

  [data-project-cover] {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--site-duration-image) var(--site-ease-out);
  }

  .project-media__fallback {
    position: absolute;
    inset: 0;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    overflow: hidden;
    background:
      radial-gradient(
        circle at 78% 20%,
        color-mix(in srgb, var(--site-color-accent) 18%, transparent),
        transparent 34%
      ),
      linear-gradient(
        135deg,
        var(--site-color-navy-deep),
        var(--site-color-surface) 58%,
        var(--site-color-background)
      );
  }

  .project-media__grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.28;
    background-image:
      linear-gradient(var(--site-color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--site-color-border) 1px, transparent 1px);
    background-size: clamp(2rem, 6vw, 4rem) clamp(2rem, 6vw, 4rem);
    mask-image: linear-gradient(to bottom right, black, transparent 80%);
  }

  .project-media__fallback-content {
    display: grid;
    max-width: 28rem;
    gap: 0.35rem;
  }

  .project-media__fallback-content strong {
    color: var(--site-color-text);
    font-size: clamp(1rem, 2.4vw, 1.5rem);
    line-height: 1.2;
  }

  .project-media__fallback-content > span:last-child {
    color: var(--site-color-text-muted);
    font-size: var(--site-text-sm);
  }

  .project-media__wordmark {
    color: var(--site-color-accent);
    font-size: var(--site-text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
  }
</style>
