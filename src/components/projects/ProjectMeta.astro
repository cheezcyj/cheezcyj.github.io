---
import type { ProjectEntry } from '../../utils/projects'
import { getProjectPeriod, getProjectStatusLabel } from '../../utils/projects'

interface Props {
  entry: ProjectEntry
}

const { entry } = Astro.props
const { roles, stack, status } = entry.data
const period = getProjectPeriod(entry)
---

<dl class="project-meta">
  <div>
    <dt>상태</dt>
    <dd>{getProjectStatusLabel(status)}</dd>
  </div>
  {
    period && (
      <div>
        <dt>기간</dt>
        <dd>{period}</dd>
      </div>
    )
  }
  {
    roles.length > 0 && (
      <div>
        <dt>역할</dt>
        <dd>{roles.join(', ')}</dd>
      </div>
    )
  }
  <div>
    <dt>기술</dt>
    <dd>
      <ul class="project-meta__stack" aria-label="사용 기술">
        {stack.map((item) => <li>{item}</li>)}
      </ul>
    </dd>
  </div>
</dl>

<style>
  .project-meta {
    display: grid;
    gap: 1.25rem;
    margin: 0;
  }

  .project-meta > div {
    display: grid;
    gap: 0.25rem;
    padding-bottom: 1rem;
    border-bottom: var(--site-border-thin) solid var(--site-color-border);
  }

  .project-meta dt {
    color: var(--site-color-text-muted);
    font-size: var(--site-text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .project-meta dd {
    margin: 0;
    color: var(--site-color-text);
    line-height: 1.55;
    overflow-wrap: break-word;
    text-wrap: pretty;
    word-break: keep-all;
  }

  .project-meta__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-meta__stack li {
    border: var(--site-border-thin) solid var(--site-color-border);
    border-radius: var(--site-radius-pill);
    background: var(--site-color-surface-muted);
    padding: 0.28rem 0.7rem;
    color: var(--site-color-text-muted);
    font-size: var(--site-text-xs);
    font-weight: 600;
    overflow-wrap: break-word;
  }
</style>
