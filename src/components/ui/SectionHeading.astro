---
interface Props {
  eyebrow: string
  title: string
  description?: string
}

const { eyebrow, title, description } = Astro.props
---

<header class="mb-8 max-w-3xl">
  <p
    class="mb-2 text-site-xs font-semibold tracking-[0.2em] text-site-accent uppercase"
  >
    {eyebrow}
  </p>
  <h2
    class="text-site-section leading-tight font-bold tracking-tight text-site-text"
  >
    {title}
  </h2>
  {
    description && (
      <p class="mt-3 max-w-2xl text-site-base leading-relaxed text-site-muted">
        {description}
      </p>
    )
  }
</header>
