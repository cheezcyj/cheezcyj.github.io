---
import { navigation, siteConfig } from '../../config/site'

const currentYear = new Date().getFullYear()
---

<footer
  class="relative z-[var(--site-z-content)] border-t border-site-border"
  data-site-footer
>
  <div class="site-container py-14">
    <div
      class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between"
    >
      <div class="max-w-sm">
        <p class="text-site-xl font-extrabold tracking-tight text-site-text">
          {siteConfig.title}
        </p>
        <p class="mt-3 text-site-sm leading-relaxed text-site-muted">
          {siteConfig.roles.join(' · ')}
        </p>
      </div>

      <nav aria-label="푸터 메뉴">
        <ul
          class="flex max-w-md list-none flex-wrap gap-x-6 gap-y-2 p-0 text-site-sm"
        >
          {
            navigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="rounded-site-sm text-site-muted transition-colors hover:text-site-accent"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex items-center gap-4 text-site-sm font-semibold">
        <a
          href={`mailto:${siteConfig.email}`}
          class="rounded-site-sm text-site-muted transition-colors hover:text-site-accent"
        >
          Email
        </a>
        <a
          href={siteConfig.github}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-site-sm text-site-muted transition-colors hover:text-site-accent"
        >
          GitHub
        </a>
      </div>
    </div>

    <p
      class="mt-12 border-t border-site-border pt-6 text-site-sm text-site-muted"
    >
      © {currentYear}
      {siteConfig.title}. All rights reserved.
    </p>
  </div>
</footer>
