---
import SkipToContent from '../components/ui/SkipToContent.astro'
import { siteConfig } from '../config/site'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonicalPath?: string
  robots?: string
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonicalPath,
  robots,
} = Astro.props
const pageTitle =
  title === siteConfig.title ? title : `${title} — ${siteConfig.title}`
const canonical = new URL(canonicalPath ?? Astro.url.pathname, siteConfig.url)
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#070b16" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={siteConfig.alternateName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <SkipToContent />
    <slot />
  </body>
</html>
