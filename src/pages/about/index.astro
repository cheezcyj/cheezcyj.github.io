---
import SiteFooter from '../../components/layout/SiteFooter.astro'
import SiteHeader from '../../components/layout/SiteHeader.astro'
import SectionHeading from '../../components/ui/SectionHeading.astro'
import { aboutContent } from '../../config/about'
import { siteConfig } from '../../config/site'
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="About" description={aboutContent.description}>
  <div class="relative z-[var(--site-z-content)] min-h-screen">
    <SiteHeader />
    <main id="main-content" data-site-main tabindex="-1">
      <section class="border-b border-site-border" aria-labelledby="page-title">
        <div
          class="site-container grid items-center gap-12 py-section-lg lg:grid-cols-[minmax(0,1.05fr)_minmax(20rem,0.95fr)] lg:gap-16"
        >
          <header class="min-w-0 max-w-3xl">
            <p
              class="mb-3 text-site-xs font-semibold tracking-[0.2em] text-site-accent uppercase"
            >
              CHOE YOOJEONG · About
            </p>
            <h1
              id="page-title"
              class="text-site-hero-tagline leading-[1.05] font-bold tracking-tight text-balance text-site-text"
            >
              {aboutContent.headline}
            </h1>
            <p
              class="mt-8 max-w-2xl text-site-lg leading-relaxed text-pretty text-site-text/90 [word-break:keep-all]"
            >
              {aboutContent.introduction}
            </p>
            <p
              class="mt-4 max-w-2xl text-site-base leading-relaxed text-pretty text-site-muted [word-break:keep-all]"
            >
              {aboutContent.detail}
            </p>

            <ul
              class="mt-8 flex list-none flex-wrap gap-x-3 gap-y-2 p-0"
              aria-label="주요 직무"
            >
              {
                siteConfig.roles.map((role, index) => (
                  <li class="flex items-center gap-3 text-site-xs font-semibold tracking-[0.14em] text-site-muted uppercase sm:text-site-sm">
                    {index > 0 && (
                      <span
                        class="size-1 shrink-0 rounded-full bg-site-accent"
                        aria-hidden="true"
                      />
                    )}
                    {role}
                  </li>
                ))
              }
            </ul>

            <nav class="mt-10" aria-label="소개 페이지 바로가기">
              <a
                href="/projects/"
                class="inline-flex min-h-11 items-center gap-2 rounded-site-pill bg-site-accent px-6 py-3 text-site-sm font-bold text-site-bg transition-colors hover:bg-site-accent-strong"
              >
                프로젝트 보기 <span aria-hidden="true">→</span>
              </a>
            </nav>
          </header>

          <div class="about-mark" aria-hidden="true">
            <div class="about-mark__topline">
              <span>CHEEZCYJ</span>
              <span>PORTFOLIO / ARCHIVE</span>
            </div>
            <strong class="about-mark__monogram">CYJ</strong>
            <p class="about-mark__caption">DESIGN · PUBLISH · BUILD</p>
          </div>
        </div>
      </section>

      <section class="section-shell" aria-labelledby="disciplines-title">
        <div class="site-container">
          <SectionHeading
            eyebrow="What I Do"
            title="하나의 경험을 여러 관점에서 만듭니다."
            titleId="disciplines-title"
            description="시각적 기준을 세우고, 화면으로 옮기고, 실제 기능으로 연결하는 과정을 함께 다룹니다."
          />

          <ul class="grid list-none gap-4 p-0 md:grid-cols-2 lg:grid-cols-3">
            {
              aboutContent.disciplines.map((discipline) => (
                <li class="min-w-0 rounded-site-xl border border-site-border bg-site-surface p-6 sm:p-7">
                  <div class="flex items-start justify-between gap-4">
                    <span class="font-mono text-site-sm font-semibold text-site-accent">
                      {discipline.number}
                    </span>
                    <span class="text-right text-site-xs font-semibold tracking-[0.14em] text-site-muted uppercase">
                      {discipline.label}
                    </span>
                  </div>
                  <h3 class="mt-10 text-site-xl font-bold tracking-tight text-site-text">
                    {discipline.title}
                  </h3>
                  <p class="mt-4 text-site-base leading-relaxed text-pretty text-site-muted">
                    {discipline.description}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section
        class="section-shell border-y border-site-border bg-site-navy-deep/30"
        aria-labelledby="experience-title"
      >
        <div class="site-container">
          <SectionHeading
            eyebrow="Selected Experience"
            title="프로젝트에서 확인한 경험"
            titleId="experience-title"
            description="공개된 프로젝트에서 확인할 수 있는 역할만 정리했습니다."
          />

          <ul class="max-w-3xl list-none p-0">
            {
              aboutContent.experiences.map((experience) => (
                <li class="flex min-w-0 flex-col rounded-site-xl border border-site-border bg-site-bg/50 p-6 sm:p-8">
                  <p class="text-site-xs font-semibold tracking-[0.16em] text-site-accent uppercase">
                    {experience.eyebrow}
                  </p>
                  <h3 class="mt-3 text-site-section leading-tight font-bold tracking-tight text-site-text">
                    {experience.title}
                  </h3>
                  <p class="mt-4 text-site-base leading-relaxed text-pretty text-site-muted">
                    {experience.description}
                  </p>
                  <a
                    href={experience.href}
                    class="mt-8 inline-flex min-h-11 items-center gap-2 self-start rounded-site-md font-semibold text-site-text underline decoration-site-border underline-offset-4 transition-colors hover:text-site-accent hover:decoration-site-accent focus-visible:text-site-accent"
                  >
                    {experience.linkLabel} <span aria-hidden="true">→</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="section-shell" aria-labelledby="capabilities-title">
        <div class="site-container">
          <SectionHeading
            eyebrow="Capabilities"
            title="작업에 사용하는 기술과 기준"
            titleId="capabilities-title"
            description="실제 프로젝트와 이 사이트에서 사용한 기술을 숙련도 수치 없이 정리했습니다."
          />

          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            {
              aboutContent.capabilityGroups.map((group, groupIndex) => (
                <section
                  class="min-w-0 rounded-site-xl border border-site-border p-6"
                  aria-labelledby={`capability-group-${groupIndex}`}
                >
                  <h3
                    id={`capability-group-${groupIndex}`}
                    class="text-site-lg font-bold text-site-text"
                  >
                    {group.title}
                  </h3>
                  <ul class="mt-5 flex list-none flex-wrap gap-2 p-0">
                    {group.items.map((item) => (
                      <li class="max-w-full rounded-site-pill border border-site-border bg-site-surface px-3 py-1.5 text-site-sm text-site-muted [overflow-wrap:anywhere]">
                        {item}
                      </li>
                    ))}
                  </ul>
                </section>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="section-shell border-y border-site-border bg-site-surface"
        aria-labelledby="principles-title"
      >
        <div
          class="site-container grid gap-10 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)] lg:gap-16"
        >
          <header class="max-w-xl">
            <p
              class="mb-3 text-site-xs font-semibold tracking-[0.2em] text-site-accent uppercase"
            >
              How I Work
            </p>
            <h2
              id="principles-title"
              class="text-site-section leading-tight font-bold tracking-tight text-balance text-site-text"
            >
              결과만큼 과정의 기준을 중요하게 생각합니다.
            </h2>
          </header>

          <ol class="m-0 list-none border-t border-site-border p-0">
            {
              aboutContent.principles.map((principle) => (
                <li class="grid gap-3 border-b border-site-border py-6 sm:grid-cols-[3rem_minmax(0,1fr)] sm:gap-5">
                  <span class="font-mono text-site-sm font-semibold text-site-accent">
                    {principle.number}
                  </span>
                  <div class="min-w-0">
                    <h3 class="text-site-lg font-bold text-site-text">
                      {principle.title}
                    </h3>
                    <p class="mt-2 text-site-base leading-relaxed text-pretty text-site-muted">
                      {principle.description}
                    </p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="section-shell" aria-labelledby="contact-title">
        <div class="site-container">
          <div
            class="grid gap-8 rounded-site-xl border border-site-border bg-site-navy-deep/40 p-6 sm:p-10 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end lg:p-12"
          >
            <header class="max-w-2xl">
              <p
                class="mb-3 text-site-xs font-semibold tracking-[0.2em] text-site-accent uppercase"
              >
                Contact
              </p>
              <h2
                id="contact-title"
                class="text-site-section leading-tight font-bold tracking-tight text-balance text-site-text"
              >
                프로젝트와 기록은 계속 이어집니다.
              </h2>
              <p
                class="mt-4 text-site-base leading-relaxed text-pretty text-site-muted"
              >
                작업에 관한 이야기는 이메일로, 공개 코드는 GitHub에서 확인할 수
                있습니다.
              </p>
            </header>

            <address class="flex flex-wrap gap-3 not-italic">
              <a
                href={`mailto:${siteConfig.email}`}
                class="inline-flex min-h-11 items-center rounded-site-pill bg-site-accent px-6 py-3 text-site-sm font-bold text-site-bg transition-colors hover:bg-site-accent-strong"
              >
                이메일 보내기
              </a>
              <a
                href={siteConfig.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-11 items-center gap-2 rounded-site-pill border border-site-border px-6 py-3 text-site-sm font-bold text-site-text transition-colors hover:border-site-accent hover:text-site-accent focus-visible:border-site-accent focus-visible:text-site-accent"
              >
                GitHub 프로필 보기 <span aria-hidden="true">↗</span>
                <span class="sr-only">(새 창)</span>
              </a>
            </address>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .about-mark {
    position: relative;
    isolation: isolate;
    display: flex;
    min-width: 0;
    min-height: clamp(20rem, 60vw, 30rem);
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    border: var(--site-border-thin) solid var(--site-color-border);
    border-radius: var(--site-radius-xl);
    padding: clamp(1.25rem, 5vw, 2.5rem);
    background:
      radial-gradient(circle at 82% 16%, rgb(230 167 0 / 24%), transparent 38%),
      linear-gradient(
        145deg,
        var(--site-color-surface-muted),
        var(--site-color-navy-deep)
      );
  }

  .about-mark::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    background-image:
      linear-gradient(rgb(244 236 216 / 6%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(244 236 216 / 6%) 1px, transparent 1px);
    background-size: 2rem 2rem;
    content: '';
    mask-image: linear-gradient(to bottom, black, transparent 82%);
  }

  .about-mark__topline {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    font-family: var(--site-font-mono);
    font-size: var(--site-text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--site-color-text-muted);
  }

  .about-mark__monogram {
    align-self: center;
    font-size: clamp(5rem, 22vw, 12rem);
    line-height: 0.75;
    letter-spacing: -0.09em;
    color: var(--site-color-text);
    text-shadow: 0 0 4rem rgb(230 167 0 / 18%);
  }

  .about-mark__caption {
    margin: 0;
    font-size: var(--site-text-sm);
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--site-color-accent);
  }

  @media (min-width: 64rem) {
    .about-mark {
      min-height: 32rem;
    }

    .about-mark__monogram {
      font-size: clamp(8rem, 13vw, 12rem);
    }
  }
</style>
