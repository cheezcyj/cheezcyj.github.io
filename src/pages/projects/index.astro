---
import { getCollection } from 'astro:content'
import ProjectCard from '../../components/cards/ProjectCard.astro'
import SiteFooter from '../../components/layout/SiteFooter.astro'
import SiteHeader from '../../components/layout/SiteHeader.astro'
import EmptyState from '../../components/ui/EmptyState.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import {
  getPublishedEntries,
  isPublishableEntry,
  sortEntries,
} from '../../utils/content'

const entries = import.meta.env.DEV
  ? sortEntries(await getCollection('projects'))
  : await getPublishedEntries('projects')
const description =
  '풀스택 구현 과정과 기술 선택, 역할과 결과를 확인할 수 있는 개발 프로젝트 목록입니다.'
const hasDraftPreviews =
  import.meta.env.DEV && entries.some((entry) => !isPublishableEntry(entry))
---

<BaseLayout title="Development Projects" description={description}>
  <div class="relative z-[var(--site-z-content)] min-h-screen">
    <SiteHeader />
    <main id="main-content" data-site-main tabindex="-1">
      <section class="section-shell" aria-labelledby="page-title">
        <div class="site-container">
          <header class="mb-10 max-w-3xl">
            <p
              class="mb-2 text-site-xs font-semibold tracking-[0.2em] text-site-accent uppercase"
            >
              Fullstack Engineering
            </p>
            <h1
              id="page-title"
              class="text-site-section leading-tight font-bold tracking-tight text-site-text"
            >
              Development Projects
            </h1>
            <p class="mt-4 text-site-base leading-relaxed text-site-muted">
              {description}
            </p>
          </header>

          {
            hasDraftPreviews && (
              <p class="projects-preview-note">
                <strong>Local Draft Preview</strong>
                비공개 프로젝트를 개발 환경에서만 표시하고 있습니다.
              </p>
            )
          }

          {
            entries.length === 0 ? (
              <EmptyState
                title="개발 프로젝트를 정리 중입니다."
                description="검증된 저장소와 설명, 링크를 갖춘 프로젝트만 공개합니다."
              />
            ) : (
              <ul class="projects-grid">
                {entries.map((entry) => (
                  <li>
                    <ProjectCard
                      entry={entry}
                      headingLevel="h2"
                      preview={
                        import.meta.env.DEV && !isPublishableEntry(entry)
                      }
                    />
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .projects-preview-note {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    margin: 0 0 1.5rem;
    border-left: 2px solid var(--site-color-accent);
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--site-color-accent) 7%, transparent);
    color: var(--site-color-text-muted);
    font-size: var(--site-text-sm);
  }

  .projects-preview-note strong {
    color: var(--site-color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .projects-grid > li {
    min-width: 0;
  }

  @media (min-width: 48rem) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .projects-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
