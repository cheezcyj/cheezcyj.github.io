{
  "name": "cheezcyj-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:content": "node scripts/verify-content.mjs",
    "format": "prettier --no-error-on-unmatched-pattern --write \"src/**/*.{astro,ts,mts,css,mjs}\" \"src/content/**/*.{md,mdx}\" \"scripts/**/*.mjs\" \"docs/**/*.{md,json}\" \"*.{json,mjs}\" .prettierrc.mjs \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --no-error-on-unmatched-pattern --check \"src/**/*.{astro,ts,mts,css,mjs}\" \"src/content/**/*.{md,mdx}\" \"scripts/**/*.mjs\" \"docs/**/*.{md,json}\" \"*.{json,mjs}\" .prettierrc.mjs \".github/**/*.{yml,yaml}\""
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.9",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "picomatch": "4.0.5",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "yaml": "2.9.0"
  }
}
